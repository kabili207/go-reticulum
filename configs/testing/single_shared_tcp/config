[reticulum]
  share_instance = Yes
  instance_name = single
  shared_instance_type = tcp
  shared_instance_port = 37428
  instance_control_port = 37429
  enable_transport = No

[logging]
  loglevel = 4

[interfaces]
  # Start without any "physical" interfaces. Handy for CLI utility tests where
  # only the shared instance (LocalInterface IPC) matters.
  [[Noop]]
    type = UDPInterface
    enabled = no
    listen_ip = 127.0.0.1
    listen_port = 0
    forward_ip = 127.0.0.1
    forward_port = 0
